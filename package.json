{
  "name": "pr-status-monitor__",
  "displayName": "PR Status Monitor",
  "description": "Real-time GitHub Pull Request (PR) CI/CD status monitor, build failure alerts, and Git worktree action notifications directly in your VS Code status bar.",
  "version": "0.0.1-dev.12",
  "_last_dev_versioning_for_cache": "0.0.1-dev.11",
  "license": "MIT",
  "publisher": "ah584d",
  "author": {
    "name": "Avraham Hamu",
    "email": "gibor7@gmail.com"
  },
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ah584d/vscode-plugin-pr-status.git"
  },
  "homepage": "https://github.com/ah584d/vscode-plugin-pr-status#readme",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "pull-request",
    "ci-cd",
    "git",
    "workflow",
    "status-bar"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pr-status-monitor.openPrInBrowser",
        "title": "Open PR in Browser"
      }
    ],
    "configuration": {
      "title": "PR Status Monitor",
      "properties": {
        "prStatusMonitor.pollingInterval": {
          "type": "number",
          "default": 2,
          "minimum": 0.5,
          "maximum": 60,
          "description": "How often to check PR status (in minutes). Minimum 0.5 (30 seconds)."
        },
        "prStatusMonitor.showInvestigateOnFailure": {
          "type": "boolean",
          "default": false,
          "description": "Show an 'Investigate' button in the failure notification that opens Copilot Chat to explain the build failure"
        }
      }
    }
  },
  "telemetry": "all-supported",
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "build": "pnpm dlx @vscode/vsce package --no-dependencies",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "pnpm compile-tests && vscode-test",
    "publish:login": "pnpm dlx @vscode/vsce login ah584d",
    "publish": "pnpm dlx @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.103.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@vscode/extension-telemetry": "^1.5.2"
  }
}
